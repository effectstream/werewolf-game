{
  "name": "@werewolf-game/admin-ui",
  "version": "0.1.0",
  "exports": {
    ".": "./client/src/main.tsx"
  },
  "tasks": {
    "dev": "deno run -A --node-modules-dir=auto npm:vite --port 10599"
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.4",
    "@types/react": "npm:@types/react@^19.1.2",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.4.1",
    "react": "npm:react@19.1.0",
    "react-dom": "npm:react-dom@19.1.0",
    "vite": "npm:vite@7.1.3"
  },
  "compilerOptions": {
    "types": ["react", "react-dom", "@types/react"],
    "lib": ["dom", "dom.iterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "types": ["vite/client"]
}
