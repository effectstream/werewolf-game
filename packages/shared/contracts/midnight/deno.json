{
    "name": "@example-midnight/midnight-contracts",
    "version": "0.3.22",
    "exports": {},
    "tasks": {
        "midnight-node:start": "MIDNIGHT_STORAGE_PASSWORD=yourPasswordmypassword1x2x3x4! CFG_PRESET=dev deno run -A --unstable-detect-cjs npm:@paimaexample/npm-midnight-node --dev --rpc-port 9944 --state-pruning archive --blocks-pruning archive --public-addr /ip4/127.0.0.1 --unsafe-rpc-external",
        "midnight-node:wait": "wait-on tcp:9944",
        "midnight-indexer:start": "CONFIG_FILE=`pwd`/indexer-standalone/config.yaml LEDGER_NETWORK_ID=\"Undeployed\" SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" APP__INFRA__SECRET=$(openssl rand -hex 32 | tr 'a-f' 'A-F') FEATURES_WALLET_ENABLED=\"true\" APP__INFRA__NODE__URL=\"ws://localhost:9944\" deno run -A --unstable-detect-cjs npm:@paimaexample/npm-midnight-indexer --binary --clean",
        "midnight-indexer:wait": "wait-on tcp:8088",
        "midnight-proof-server:start": "LEDGER_NETWORK_ID=\"Undeployed\" RUST_BACKTRACE=full SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" deno run -A --unstable-detect-cjs npm:@paimaexample/npm-midnight-proof-server",
        "midnight-proof-server:start:preprod": "LEDGER_NETWORK_ID=\"TestNet\" RUST_BACKTRACE=full SUBSTRATE_NODE_WS_URL=\"${SUBSTRATE_NODE_WS_URL:-wss://rpc.preprod.midnight.network}\" deno run -A --unstable-detect-cjs npm:@paimaexample/npm-midnight-proof-server",
        "midnight-proof-server:wait": "wait-on tcp:6300",
        "midnight-contract:clean": "rm -rf midnight-level-db && rm -f contract.json contract-werewolf.undeployed.json contract-werewolf.preprod.json deployment-state.json",
        "midnight-contract:deploy": "deno task midnight-contract:clean && deno --unstable-detect-cjs -A deploy.ts",
        "midnight-contract:deploy:preprod": "deno task midnight-contract:clean && deno run -A --unstable-detect-cjs deploy-preprod.ts",
        "midnight-contract:deploy:preprod:wallet": "deno run -A --unstable-detect-cjs deploy-preprod.ts --wallet",
        "midnight-contract:verify": "deno --unstable-detect-cjs -A verify-deployment.ts",
        "midnight-faucet:start": "deno run -A faucet.ts"
    },
    "imports": {
        "@paimaexample/midnight-contracts": "jsr:@paimaexample/midnight-contracts@0.10.0",
        "@paimaexample/npm-midnight-indexer": "npm:@paimaexample/npm-midnight-indexer@0.10.0",
        "@paimaexample/npm-midnight-node": "npm:@paimaexample/npm-midnight-node@0.10.0",
        "@paimaexample/npm-midnight-proof-server": "npm:@paimaexample/npm-midnight-proof-server@0.10.0",
        "@midnight-ntwrk/ledger-v7": "npm:@midnight-ntwrk/ledger-v7@7.0.3",
        "@midnight-ntwrk/ledger-v8": "npm:@midnight-ntwrk/ledger-v8@8.0.3",
        "@midnight-ntwrk/compact-js": "npm:@midnight-ntwrk/compact-js@2.5.0",
        "@midnight-ntwrk/compact-runtime": "npm:@midnight-ntwrk/compact-runtime@0.15.0",
        "@midnight-ntwrk/wallet-sdk-address-format": "npm:@midnight-ntwrk/wallet-sdk-address-format@3.1.0",
        "@midnight-ntwrk/midnight-js-types": "npm:@midnight-ntwrk/midnight-js-types@4.0.1",
        "@midnight-ntwrk/midnight-js-network-id": "npm:@midnight-ntwrk/midnight-js-network-id@4.0.1",
        "@midnight-ntwrk/midnight-js-utils": "npm:@midnight-ntwrk/midnight-js-utils@4.0.1",
        "@midnight-ntwrk/midnight-js-contracts": "npm:@midnight-ntwrk/midnight-js-contracts@4.0.1",
        "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "npm:@midnight-ntwrk/midnight-js-indexer-public-data-provider@4.0.1",
        "@midnight-ntwrk/midnight-js-http-client-proof-provider": "npm:@midnight-ntwrk/midnight-js-http-client-proof-provider@4.0.1",
        "@midnight-ntwrk/midnight-js-node-zk-config-provider": "npm:@midnight-ntwrk/midnight-js-node-zk-config-provider@4.0.1",
        "@midnight-ntwrk/midnight-js-level-private-state-provider": "npm:@midnight-ntwrk/midnight-js-level-private-state-provider@4.0.1",
        "@midnight-ntwrk/wallet-api": "npm:@midnight-ntwrk/wallet-api@5.0.0",
        "@midnight-ntwrk/wallet": "npm:@midnight-ntwrk/wallet@5.0.0",
        "@midnight-ntwrk/wallet-sdk-hd": "npm:@midnight-ntwrk/wallet-sdk-hd@3.0.1",
        "@midnight-ntwrk/wallet-sdk-facade": "npm:@midnight-ntwrk/wallet-sdk-facade@3.0.0",
        "@midnight-ntwrk/wallet-sdk-shielded": "npm:@midnight-ntwrk/wallet-sdk-shielded@2.1.0",
        "@midnight-ntwrk/wallet-sdk-shielded/v1": "npm:@midnight-ntwrk/wallet-sdk-shielded@2.1.0/v1",
        "@midnight-ntwrk/wallet-sdk-dust-wallet": "npm:@midnight-ntwrk/wallet-sdk-dust-wallet@3.0.0",
        "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "npm:@midnight-ntwrk/wallet-sdk-unshielded-wallet@2.1.0",
        "@midnight-ntwrk/wallet-sdk-abstractions": "npm:@midnight-ntwrk/wallet-sdk-abstractions@2.0.0",
        "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
        "@std/fs": "jsr:@std/fs@^1.0.19",
        "@std/log": "jsr:@std/log@^0.224.0",
        "@std/path": "jsr:@std/path@^1.1.3",
        "rxjs": "npm:rxjs@^7.8.2"
    }
}