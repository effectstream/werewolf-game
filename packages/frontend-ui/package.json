{
  "name": "werewolf-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:preprod": "vite build --mode preprod",
    "build:mainnet": "vite build --mode mainnet",
    "build:mainnet-local": "vite build --mode mainnet-local",
    "preview": "vite preview",
    "preview:mainnet-local": "vite preview --mode mainnet-local",
    "serve:preprod": "deno run --allow-net --allow-read --allow-env scripts/serve-preprod.ts",
    "serve:mainnet": "deno run --allow-net --allow-read --allow-env scripts/serve-mainnet.ts",
    "typecheck": "tsc --noEmit",
    "fetch-midnight-params": "node scripts/fetch-midnight-params.mjs"
  },
  "devDependencies": {
    "@types/three": "^0.183.0",
    "memfs": "^4.0.0",
    "puppeteer": "^24.37.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.5.0",
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "4.0.2",
    "@paima/midnight-wasm-prover": "^0.1.0-alpha6",
    "three": "^0.183.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.21.0"
  }
}