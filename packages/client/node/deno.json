{
  "name": "@werewolf-game/node",
  "version": "0.3.22",
  "license": "MIT",
  "exports": {
    ".": "./src/main.ts"
  },
  "tasks": {
    "check": "deno check --unstable-raw-imports src/main.ts",
    "node:start": "deno run -A --inspect --unstable-raw-imports src/main.ts",
    "node:start:testnet": "deno run -A --inspect --unstable-raw-imports src/main.testnet.ts",
    "node:start:preprod": "deno run -A --env-file=../../../.env.preprod --unstable-raw-imports src/main.preprod.ts",
    "dev": "NODE_ENV=development deno run -A --check --unstable-raw-imports scripts/start.ts",
    "testnet": "EFFECTSTREAM_ENV=testnet deno run -A --check --unstable-raw-imports scripts/start.testnet.ts",
    "preprod": "EFFECTSTREAM_ENV=testnet deno run -A --env-file=../../../.env.preprod --check --unstable-raw-imports scripts/start.preprod.ts",
    "test": "deno run -A --unstable-raw-imports --check scripts/e2e.test.ts"
  },
  "imports": {
    "@paimaexample/concise": "jsr:@paimaexample/concise@0.10.1",
